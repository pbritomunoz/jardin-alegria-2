{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about a registered customer",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "nombre": { "type": "string" },
        "apellido": { "type": "string" },
        "email": { "type": "string" },
        "telefono": { "type": "string" },
        "direccion": { "type": "string" }
      },
      "required": ["uid", "nombre", "apellido", "email", "telefono"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles"
    }
  }
}
